    <item>
      <title>User-Defined Functions</title>
      <link>https://ferretlang.org/docs/language/functions/user-defined/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://ferretlang.org/docs/language/functions/user-defined/</guid>
      <description>&lt;h1 id=&#34;user-defined-functions&#34;&gt;User-defined functions&lt;/h1&gt;&#xA;&lt;p&gt;A user-defined function is a reusable piece of logic declared within a script. Once declared, the function can be called like any built-in function.&lt;/p&gt;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&lt;div class=&#34;code-editor is-horizontal is-auto-height&#34;&gt;&#xA;    &lt;textarea id=&#34;code-editor-1-copy-clipboard&#34; class=&#34;code-editor-clipboard&#34; tabindex=&#34;-1&#34; aria-hidden=&#34;true&#34;&gt;&lt;/textarea&gt;&#xA;&#xA;    &lt;div class=&#34;code-editor-shell&#34;&gt;&#xA;        &lt;div id=&#34;code-editor-1-header&#34; class=&#34;code-editor-header&#34;&gt;&#xA;            &lt;div class=&#34;code-editor-title&#34;&gt;&#xA;                &lt;span class=&#34;code-editor-dot&#34; aria-hidden=&#34;true&#34;&gt;&lt;/span&gt;&#xA;                &lt;span&gt;example.fql&lt;/span&gt;&#xA;                &lt;small&gt;Ferret v2&lt;/small&gt;&#xA;            &lt;/div&gt;&#xA;&#xA;            &lt;div class=&#34;code-editor-actions&#34;&gt;&#xA;                &lt;button id=&#34;code-editor-1-result-toggle-button&#34; class=&#34;button is-outlined is-light code-editor-button&#34; type=&#34;button&#34; aria-expanded=&#34;false&#34; aria-controls=&#34;code-editor-1-result-pane&#34;&gt;Output&lt;/button&gt;&#xA;                &lt;button id=&#34;code-editor-1-params-toggle-button&#34; class=&#34;button is-outlined is-light code-editor-button&#34; type=&#34;button&#34; aria-expanded=&#34;false&#34; aria-controls=&#34;code-editor-1-params-drawer&#34;&gt;Params&lt;/button&gt;&#xA;                &lt;button id=&#34;code-editor-1-run-button&#34; class=&#34;run button is-outlined is-light code-editor-button&#34; type=&#34;button&#34; aria-label=&#34;Run query&#34;&gt;&#xA;                    &lt;span class=&#34;code-editor-run-label&#34;&gt;Run&lt;/span&gt;&#xA;                    &lt;span id=&#34;code-editor-1-run-button-spinner&#34; class=&#34;code-editor-run-spinner&#34; aria-hidden=&#34;true&#34;&gt;&lt;/span&gt;&#xA;                &lt;/button&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div id=&#34;code-editor-1-progress&#34; class=&#34;code-editor-progress&#34; role=&#34;progressbar&#34; aria-label=&#34;Running query&#34; hidden&gt;&lt;/div&gt;&#xA;            &lt;span id=&#34;code-editor-1-run-status&#34; class=&#34;code-editor-sr-only&#34; aria-live=&#34;polite&#34; aria-atomic=&#34;true&#34;&gt;&lt;/span&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &lt;div class=&#34;code-editor-workspace&#34;&gt;&#xA;            &lt;div id=&#34;code-editor-1-grid&#34; class=&#34;code-editor-grid&#34; style=&#34;grid-template-columns: 1fr;&#34;&gt;&#xA;                &lt;div id=&#34;code-editor-1-source-pane&#34; class=&#34;code-editor-pane code-editor-pane-source&#34;&gt;&#xA;                    &lt;div class=&#34;code-editor-pane-header&#34;&gt;&#xA;                        &lt;span&gt;query.fql&lt;/span&gt;&#xA;                        &lt;div class=&#34;code-editor-pane-header-actions&#34;&gt;&#xA;                            &lt;span&gt;FQL&lt;/span&gt;&#xA;                            &lt;button id=&#34;code-editor-1-copy-button&#34; class=&#34;code-editor-pane-button&#34; type=&#34;button&#34;&gt;Copy&lt;/button&gt;&#xA;                        &lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;div id=&#34;code-editor-1-text&#34; class=&#34;code-editor-text&#34; data-auto-height=&#34;true&#34;&gt;FUNC double(x) =&amp;gt; x * 2&#xA;&#xA;RETURN double(21)&lt;/div&gt;&#xA;                &lt;/div&gt;&#xA;&#xA;                &lt;div id=&#34;code-editor-1-result-pane&#34; class=&#34;code-editor-pane code-editor-pane-result&#34; hidden&gt;&#xA;                    &lt;div class=&#34;code-editor-pane-header&#34;&gt;&#xA;                        &lt;span&gt;result.json&lt;/span&gt;&#xA;                        &lt;div class=&#34;code-editor-pane-header-actions&#34;&gt;&#xA;                            &lt;span&gt;output&lt;/span&gt;&#xA;                            &lt;button id=&#34;code-editor-1-result-close-button&#34; class=&#34;code-editor-pane-button&#34; type=&#34;button&#34; aria-controls=&#34;code-editor-1-result-pane&#34;&gt;Close&lt;/button&gt;&#xA;                        &lt;/div&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;div id=&#34;code-editor-1-result&#34; class=&#34;code-editor-result&#34; data-auto-height=&#34;true&#34;&gt;&lt;/div&gt;&#xA;                &lt;/div&gt;&#xA;            &lt;/div&gt;&#xA;&#xA;            &lt;aside id=&#34;code-editor-1-params-drawer&#34; class=&#34;code-editor-params-drawer&#34; aria-labelledby=&#34;code-editor-1-params-title&#34; hidden&gt;&#xA;                &lt;div class=&#34;code-editor-params-header&#34;&gt;&#xA;                    &lt;div&gt;&#xA;                        &lt;span id=&#34;code-editor-1-params-title&#34; class=&#34;code-editor-params-title&#34;&gt;Query parameters&lt;/span&gt;&#xA;                        &lt;span class=&#34;code-editor-params-description&#34;&gt;Values are parsed as JSON when possible.&lt;/span&gt;&#xA;                    &lt;/div&gt;&#xA;                    &lt;button id=&#34;code-editor-1-params-close-button&#34; class=&#34;code-editor-pane-button&#34; type=&#34;button&#34;&gt;Close&lt;/button&gt;&#xA;                &lt;/div&gt;&#xA;                &lt;div class=&#34;code-editor-params-body&#34;&gt;&#xA;                    &lt;div id=&#34;code-editor-1-params-empty&#34; class=&#34;code-editor-params-empty&#34;&gt;No parameters added.&lt;/div&gt;&#xA;                    &lt;div id=&#34;code-editor-1-params-rows&#34; class=&#34;code-editor-params-rows&#34;&gt;&lt;/div&gt;&#xA;                &lt;/div&gt;&#xA;                &lt;div class=&#34;code-editor-params-footer&#34;&gt;&#xA;                    &lt;button id=&#34;code-editor-1-params-add-button&#34; class=&#34;code-editor-params-add-button&#34; type=&#34;button&#34;&gt;Add parameter&lt;/button&gt;&#xA;                &lt;/div&gt;&#xA;            &lt;/aside&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;script&gt;&#xA;        document.addEventListener(&#39;DOMContentLoaded&#39;, function () {&#xA;            function createEditor(id, mode, useWorker) {&#xA;                const editor = ace.edit(id);&#xA;                editor.setTheme(&#34;ace\/theme\/tomorrow_night&#34;);&#xA;                editor.session.setUseWorker(useWorker);&#xA;                editor.session.setMode(&#34;ace/mode/&#34; + mode);&#xA;                editor.setOptions({&#xA;                    displayIndentGuides: false,&#xA;                    printMargin: false&#xA;                });&#xA;&#xA;                return editor;&#xA;            }&#xA;&#xA;            const btn = document.querySelector(&#39;#code-editor-1-run-button&#39;);&#xA;            const textEditor = createEditor(&#39;code-editor-1-text&#39;, &#39;fql&#39;, true);&#xA;            const resultEditor = createEditor(&#39;code-editor-1-result&#39;, &#39;json&#39;, false);&#xA;            resultEditor.setReadOnly(true);&#xA;            const resultExpandBtn = null;&#xA;            const editorHeader = document.querySelector(&#39;#code-editor-1-header&#39;);&#xA;            const editorWorkspace = document.querySelector(&#39;#code-editor-1-grid&#39;).parentElement;&#xA;            const editorGrid = document.querySelector(&#39;#code-editor-1-grid&#39;);&#xA;            const runProgress = document.querySelector(&#39;#code-editor-1-progress&#39;);&#xA;            const runStatus = document.querySelector(&#39;#code-editor-1-run-status&#39;);&#xA;            const resultPane = document.querySelector(&#39;#code-editor-1-result-pane&#39;);&#xA;            const resultToggleBtn = document.querySelector(&#39;#code-editor-1-result-toggle-button&#39;);&#xA;            const resultCloseBtn = document.querySelector(&#39;#code-editor-1-result-close-button&#39;);&#xA;            const paramsToggleBtn = document.querySelector(&#39;#code-editor-1-params-toggle-button&#39;);&#xA;            const paramsDrawer = document.querySelector(&#39;#code-editor-1-params-drawer&#39;);&#xA;            const paramsCloseBtn = document.querySelector(&#39;#code-editor-1-params-close-button&#39;);&#xA;            const paramsAddBtn = document.querySelector(&#39;#code-editor-1-params-add-button&#39;);&#xA;            const paramsRows = document.querySelector(&#39;#code-editor-1-params-rows&#39;);&#xA;            const paramsEmpty = document.querySelector(&#39;#code-editor-1-params-empty&#39;);&#xA;            let isResultVisible = !resultPane.hidden;&#xA;            let isParamsVisible = !paramsDrawer.hidden;&#xA;&#xA;            function resetResultExpansion() {&#xA;                if (!resultExpandBtn) {&#xA;                    return;&#xA;                }&#xA;&#xA;                isResultExpanded = false;&#xA;                resultExpandBtn.setAttribute(&#39;aria-expanded&#39;, &#39;false&#39;);&#xA;                resultExpandBtn.textContent = &#39;Expand&#39;;&#xA;            }&#xA;&#xA;            function syncEditorLayout() {&#xA;                const sourceHeight = getEditorContentHeight(textEditor);&#xA;                textEditor.container.style.height = `${sourceHeight}px`;&#xA;&#xA;                if (isResultVisible) {&#xA;                    const resultHeight = getEditorContentHeight(resultEditor);&#xA;                    applyResultHeight(resultHeight);&#xA;                }&#xA;&#xA;                textEditor.resize();&#xA;&#xA;                if (isResultVisible) {&#xA;                    resultEditor.resize();&#xA;                }&#xA;            }&#xA;&#xA;            function setResultVisible(nextVisible) {&#xA;                isResultVisible = nextVisible;&#xA;                resultPane.hidden = !nextVisible;&#xA;                resultToggleBtn.setAttribute(&#39;aria-expanded&#39;, nextVisible ? &#39;true&#39; : &#39;false&#39;);&#xA;                editorGrid.style.gridTemplateColumns = nextVisible ? &#39;&#39; : &#39;1fr&#39;;&#xA;&#xA;                if (!nextVisible) {&#xA;                    resetResultExpansion();&#xA;                    syncEditorLayout();&#xA;                    return;&#xA;                }&#xA;&#xA;                window.requestAnimationFrame(() =&gt; {&#xA;                    syncEditorLayout();&#xA;                    resultEditor.resize(true);&#xA;                });&#xA;            }&#xA;&#xA;            resultToggleBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                setResultVisible(!isResultVisible);&#xA;            });&#xA;&#xA;            resultCloseBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                setResultVisible(false);&#xA;            });&#xA;&#xA;            const collapsedResultHeightStyle = resultEditor.container.style.height;&#xA;            let isResultExpanded = false;&#xA;&#xA;            function getEditorContentHeight(editor) {&#xA;                const lineHeight = editor.renderer.lineHeight || 21;&#xA;                const screenLines = Math.max(editor.session.getScreenLength(), 1);&#xA;&#xA;                return Math.max(screenLines * lineHeight, 48);&#xA;            }&#xA;&#xA;            function getMaxResultHeight(fallbackHeight) {&#xA;                const viewportHeight = window.innerHeight || document.documentElement.clientHeight || fallbackHeight;&#xA;                const rootFontSize = parseFloat(window.getComputedStyle(document.documentElement).fontSize) || 16;&#xA;&#xA;                return Math.min(viewportHeight * 0.45, 32 * rootFontSize);&#xA;            }&#xA;&#xA;            function getCollapsedResultHeight() {&#xA;                return getEditorContentHeight(resultEditor);&#xA;            }&#xA;&#xA;            function getExpandedResultHeight(collapsedHeight) {&#xA;                const lineHeight = resultEditor.renderer.lineHeight || textEditor.renderer.lineHeight || 21;&#xA;                const maxAllowedHeight = getMaxResultHeight(collapsedHeight);&#xA;                const screenLines = Math.max(resultEditor.session.getScreenLength(), 1);&#xA;                const contentHeight = (screenLines * lineHeight) + (lineHeight * 2);&#xA;                const targetHeight = Math.min(contentHeight, maxAllowedHeight);&#xA;&#xA;                return Math.max(collapsedHeight, Math.round(targetHeight));&#xA;            }&#xA;&#xA;            function applyResultHeight(collapsedHeight) {&#xA;                if (resultExpandBtn &amp;&amp; isResultExpanded) {&#xA;                    resultEditor.container.style.height = `${getExpandedResultHeight(collapsedHeight)}px`;&#xA;                } else {&#xA;                    resultEditor.container.style.height = `${Math.min(collapsedHeight, getMaxResultHeight(collapsedHeight))}px`;&#xA;                }&#xA;&#xA;                resultEditor.resize();&#xA;            }&#xA;            textEditor.session.on(&#39;change&#39;, syncEditorLayout);&#xA;&#xA;            if (resultExpandBtn) {&#xA;                resultExpandBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                    isResultExpanded = !isResultExpanded;&#xA;                    resultExpandBtn.setAttribute(&#39;aria-expanded&#39;, isResultExpanded ? &#39;true&#39; : &#39;false&#39;);&#xA;                    resultExpandBtn.textContent = isResultExpanded ? &#39;Collapse&#39; : &#39;Expand&#39;;&#xA;                    syncEditorLayout();&#xA;                });&#xA;            }&#xA;&#xA;            function syncParamsEmptyState() {&#xA;                paramsEmpty.hidden = paramsRows.children.length &gt; 0;&#xA;            }&#xA;&#xA;            function formatParamValue(value) {&#xA;                return typeof value === &#39;string&#39; ? value : JSON.stringify(value);&#xA;            }&#xA;&#xA;            function createParamRow(name, value) {&#xA;                const row = document.createElement(&#39;div&#39;);&#xA;                row.className = &#39;code-editor-param-row&#39;;&#xA;&#xA;                const nameInput = document.createElement(&#39;input&#39;);&#xA;                nameInput.className = &#39;code-editor-param-input code-editor-param-name&#39;;&#xA;                nameInput.type = &#39;text&#39;;&#xA;                nameInput.placeholder = &#39;name&#39;;&#xA;                nameInput.setAttribute(&#39;aria-label&#39;, &#39;Parameter name&#39;);&#xA;                nameInput.value = name || &#39;&#39;;&#xA;&#xA;                const separator = document.createElement(&#39;span&#39;);&#xA;                separator.className = &#39;code-editor-param-separator&#39;;&#xA;                separator.setAttribute(&#39;aria-hidden&#39;, &#39;true&#39;);&#xA;                separator.textContent = &#39;:&#39;;&#xA;&#xA;                const valueInput = document.createElement(&#39;input&#39;);&#xA;                valueInput.className = &#39;code-editor-param-input code-editor-param-value&#39;;&#xA;                valueInput.type = &#39;text&#39;;&#xA;                valueInput.placeholder = &#39;value&#39;;&#xA;                valueInput.setAttribute(&#39;aria-label&#39;, &#39;Parameter value&#39;);&#xA;                valueInput.value = value === undefined ? &#39;&#39; : formatParamValue(value);&#xA;&#xA;                const removeBtn = document.createElement(&#39;button&#39;);&#xA;                removeBtn.className = &#39;code-editor-param-remove-button&#39;;&#xA;                removeBtn.type = &#39;button&#39;;&#xA;                removeBtn.setAttribute(&#39;aria-label&#39;, `Remove parameter ${name || &#39;row&#39;}`);&#xA;                removeBtn.textContent = &#39;Remove&#39;;&#xA;                removeBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                    row.remove();&#xA;                    syncParamsEmptyState();&#xA;                });&#xA;&#xA;                row.append(nameInput, separator, valueInput, removeBtn);&#xA;                paramsRows.appendChild(row);&#xA;                syncParamsEmptyState();&#xA;&#xA;                return nameInput;&#xA;            }&#xA;&#xA;            function setParamsVisible(nextVisible) {&#xA;                isParamsVisible = nextVisible;&#xA;                paramsDrawer.hidden = !nextVisible;&#xA;                paramsToggleBtn.setAttribute(&#39;aria-expanded&#39;, nextVisible ? &#39;true&#39; : &#39;false&#39;);&#xA;                editorWorkspace.classList.toggle(&#39;is-params-open&#39;, nextVisible);&#xA;&#xA;                if (nextVisible) {&#xA;                    paramsCloseBtn.focus();&#xA;                } else {&#xA;                    paramsToggleBtn.focus();&#xA;                }&#xA;            }&#xA;&#xA;            function setParamsControlsDisabled(disabled) {&#xA;                paramsToggleBtn.disabled = disabled;&#xA;                paramsDrawer.querySelectorAll(&#39;button, input&#39;).forEach((control) =&gt; {&#xA;                    control.disabled = disabled;&#xA;                });&#xA;            }&#xA;&#xA;            function parseParamValue(value) {&#xA;                try {&#xA;                    return JSON.parse(value);&#xA;                } catch (err) {&#xA;                    return value;&#xA;                }&#xA;            }&#xA;&#xA;            function getParams() {&#xA;                return Array.from(paramsRows.querySelectorAll(&#39;.code-editor-param-row&#39;)).reduce((params, row) =&gt; {&#xA;                    const name = row.querySelector(&#39;.code-editor-param-name&#39;).value.trim();&#xA;&#xA;                    if (name) {&#xA;                        const value = row.querySelector(&#39;.code-editor-param-value&#39;).value;&#xA;                        params[name] = parseParamValue(value);&#xA;                    }&#xA;&#xA;                    return params;&#xA;                }, {});&#xA;            }&#xA;&#xA;            const initialParams = JSON.parse(&#34;{}&#34;);&#xA;&#xA;            if (initialParams &amp;&amp; typeof initialParams === &#39;object&#39; &amp;&amp; !Array.isArray(initialParams)) {&#xA;                Object.entries(initialParams).forEach(([name, value]) =&gt; {&#xA;                    createParamRow(name, value);&#xA;                });&#xA;            }&#xA;&#xA;            syncParamsEmptyState();&#xA;&#xA;            paramsToggleBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                setParamsVisible(!isParamsVisible);&#xA;            });&#xA;&#xA;            paramsCloseBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                setParamsVisible(false);&#xA;            });&#xA;&#xA;            paramsAddBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                createParamRow(&#39;&#39;, &#39;&#39;).focus();&#xA;            });&#xA;&#xA;            window.addEventListener(&#39;resize&#39;, syncEditorLayout);&#xA;            syncEditorLayout();&#xA;&#xA;            function setContent(editor, content) {&#xA;                editor.setValue(content, -1);&#xA;            }&#xA;                const copyClipboardEl = document.querySelector(&#39;#code-editor-1-copy-clipboard&#39;);&#xA;                const copyBtn = document.querySelector(&#39;#code-editor-1-copy-button&#39;);&#xA;&#xA;                function copyTextWithFallback(content) {&#xA;                    copyClipboardEl.value = content;&#xA;                    copyClipboardEl.focus();&#xA;                    copyClipboardEl.select();&#xA;&#xA;                    if (!document.execCommand(&#39;copy&#39;)) {&#xA;                        throw new Error(&#39;Could not copy source to the clipboard&#39;);&#xA;                    }&#xA;                }&#xA;&#xA;                function copyTextToClipboard(content) {&#xA;                    if (navigator.clipboard &amp;&amp; navigator.clipboard.writeText) {&#xA;                        return navigator.clipboard.writeText(content).catch(() =&gt; {&#xA;                            copyTextWithFallback(content);&#xA;                        });&#xA;                    }&#xA;&#xA;                    copyTextWithFallback(content);&#xA;&#xA;                    return Promise.resolve();&#xA;                }&#xA;&#xA;                copyBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                    copyTextToClipboard(textEditor.getValue())&#xA;                        .then(() =&gt; {&#xA;                            copyBtn.textContent = &#39;Copied&#39;;&#xA;                            window.setTimeout(() =&gt; {&#xA;                                copyBtn.textContent = &#39;Copy&#39;;&#xA;                            }, 1200);&#xA;                        })&#xA;                        .catch((err) =&gt; {&#xA;                            console.error(&#39;Failed to copy source&#39;);&#xA;                            console.error(err);&#xA;                        });&#xA;                });&#xA;&#xA;            let isRunning = false;&#xA;&#xA;            function onStart() {&#xA;                isRunning = true;&#xA;                textEditor.setReadOnly(true);&#xA;                runProgress.hidden = false;&#xA;                runStatus.textContent = &#39;Running query&#39;;&#xA;                editorHeader.setAttribute(&#39;aria-busy&#39;, &#39;true&#39;);&#xA;                editorGrid.setAttribute(&#39;aria-busy&#39;, &#39;true&#39;);&#xA;                btn.classList.add(&#39;is-running&#39;);&#xA;                btn.setAttribute(&#39;aria-busy&#39;, &#39;true&#39;);&#xA;                btn.setAttribute(&#39;aria-label&#39;, &#39;Running query&#39;);&#xA;                btn.disabled = true;&#xA;                setParamsControlsDisabled(true);&#xA;            }&#xA;&#xA;            function onEnd(result) {&#xA;                isRunning = false;&#xA;                textEditor.setReadOnly(false);&#xA;                runProgress.hidden = true;&#xA;                runStatus.textContent = &#39;&#39;;&#xA;                editorHeader.setAttribute(&#39;aria-busy&#39;, &#39;false&#39;);&#xA;                editorGrid.setAttribute(&#39;aria-busy&#39;, &#39;false&#39;);&#xA;                btn.classList.remove(&#39;is-running&#39;);&#xA;                btn.setAttribute(&#39;aria-busy&#39;, &#39;false&#39;);&#xA;                btn.setAttribute(&#39;aria-label&#39;, &#39;Run query&#39;);&#xA;                btn.disabled = false;&#xA;                setParamsControlsDisabled(false);&#xA;&#xA;                setContent(resultEditor, result);&#xA;                setResultVisible(true);&#xA;            }&#xA;&#xA;            btn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                if (isRunning) {&#xA;                    return;&#xA;                }&#xA;&#xA;                const body = {&#xA;                        text: textEditor.getValue(),&#xA;                        params: getParams()&#xA;                };&#xA;                const url = &#34;https:\/\/worker-v2-811908774949.us-east1.run.app&#34;;&#xA;&#xA;                onStart();&#xA;                fetch(url, {&#xA;                    method: &#39;post&#39;,&#xA;                    cache: &#39;no-cache&#39;,&#xA;                    headers: {&#xA;                        &#39;Content-Type&#39;: &#39;application/json; charset=utf-8&#39;&#xA;                    },&#xA;                    signal: AbortSignal.timeout(1000 * 60), &#xA;                    body: JSON.stringify(body)&#xA;                })&#xA;                    .then(r =&gt; {&#xA;                        if (r.status === 200) {&#xA;                            return r.json()&#xA;                        }&#xA;                        &#xA;                        if (r.status === 426) {&#xA;                            throw new Error(`Too many requests. Try again later.`);&#xA;                        }&#xA;                        &#xA;                        if (r.status === 400) {&#xA;                            return r.json().then((data) =&gt; {&#xA;                                if (data.details) {&#xA;                                    throw new Error(data.details);&#xA;                                }&#xA;                                &#xA;                                throw new Error(data.error);&#xA;                            });&#xA;                        }&#xA;                        &#xA;                        throw new Error(`Unexpected error. Try again later.`);&#xA;                    })&#xA;                    .then((data) =&gt; {&#xA;                        onEnd(JSON.stringify(data, null, 4));&#xA;                    })&#xA;                    .catch((err) =&gt; {&#xA;                        onEnd(err.message);&#xA;                    });&#xA;            });&#xA;        }, false);&#xA;    &lt;/script&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;h2 id=&#34;declaration&#34;&gt;Declaration&lt;/h2&gt;&#xA;&lt;p&gt;A function declaration begins with the &lt;code&gt;FUNC&lt;/code&gt; keyword, followed by a name, a parameter list in parentheses, and a body.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Module Functions</title>
      <link>https://ferretlang.org/docs/language/functions/modules/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://ferretlang.org/docs/language/functions/modules/</guid>
      <description>&lt;h1 id=&#34;module-functions&#34;&gt;Module functions&lt;/h1&gt;&#xA;&lt;p&gt;In addition to built-in functions, which are available at the top level, Ferret supports functions organized in namespaces. These namespaced functions are provided by the host application, modules, or extensions registered at engine startup. They are always available by their full qualified name — no import step is needed.&lt;/p&gt;&#xA;&lt;h2 id=&#34;namespaced-calls&#34;&gt;Namespaced calls&lt;/h2&gt;&#xA;&lt;p&gt;A namespaced function is called by prefixing the function name with the namespace and &lt;code&gt;::&lt;/code&gt;.&lt;/p&gt;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&lt;div class=&#34;code-editor is-readonly is-auto-height&#34;&gt;&#xA;&#xA;    &lt;div class=&#34;code-editor-shell&#34;&gt;&#xA;        &lt;div class=&#34;code-editor-header&#34;&gt;&#xA;            &lt;div class=&#34;code-editor-title&#34;&gt;&#xA;                &lt;span class=&#34;code-editor-dot&#34; aria-hidden=&#34;true&#34;&gt;&lt;/span&gt;&#xA;                &lt;span&gt;example.fql&lt;/span&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;span class=&#34;code-editor-meta&#34;&gt;read-only&lt;/span&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &lt;div class=&#34;code-editor-pane&#34;&gt;&#xA;            &lt;div id=&#34;code-1-text&#34; class=&#34;code-editor-text&#34; data-auto-height=&#34;true&#34;&gt;IO::FS::READ(&amp;#34;/tmp/data.json&amp;#34;)&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;script&gt;&#xA;        document.addEventListener(&#39;DOMContentLoaded&#39;, function () {&#xA;            const editor = ace.edit(&#39;code-1-text&#39;);&#xA;            editor.setTheme(&#34;ace\/theme\/tomorrow_night&#34;);&#xA;            editor.session.setUseWorker(false);&#xA;            editor.session.setMode(&#34;ace/mode/&#34; + &#39;fql&#39;);&#xA;            editor.setOptions({&#xA;                readOnly: true,&#xA;                highlightActiveLine: false,&#xA;                highlightGutterLine: false,&#xA;                displayIndentGuides: false,&#xA;                printMargin: false&#xA;            });&#xA;            editor.renderer.$cursorLayer.element.style.display = &#34;none&#34;&#xA;            function resizeAutoHeightEditor() {&#xA;                const lineHeight = editor.renderer.lineHeight || 21;&#xA;                const screenLines = Math.max(editor.session.getScreenLength(), 1);&#xA;                const nextHeight = Math.max(screenLines * lineHeight, 48);&#xA;&#xA;                editor.container.style.height = `${nextHeight}px`;&#xA;                editor.resize();&#xA;            }&#xA;&#xA;            editor.session.on(&#39;change&#39;, resizeAutoHeightEditor);&#xA;            window.addEventListener(&#39;resize&#39;, resizeAutoHeightEditor);&#xA;            resizeAutoHeightEditor();&#xA;        }, false);&#xA;    &lt;/script&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;p&gt;Namespaces can be nested. Each &lt;code&gt;::&lt;/code&gt; separator introduces another level.&lt;/p&gt;</description>
    </item>
