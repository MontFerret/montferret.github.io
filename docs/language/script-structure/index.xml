    <item>
      <title>USE Statement</title>
      <link>https://ferretlang.org/docs/language/script-structure/use/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://ferretlang.org/docs/language/script-structure/use/</guid>
      <description>&lt;h1 id=&#34;the-use-statement&#34;&gt;The USE statement&lt;/h1&gt;&#xA;&lt;p&gt;&lt;code&gt;USE&lt;/code&gt; creates a local alias for a fully qualified namespace or namespaced function. Use it when repeating a long qualified name would make a script harder to read.&lt;/p&gt;&#xA;&lt;p&gt;Aliases are resolved when the script is compiled. &lt;code&gt;USE&lt;/code&gt; does not import, load, or register a module.&lt;/p&gt;&#xA;&lt;h2 id=&#34;alias-a-namespace&#34;&gt;Alias a namespace&lt;/h2&gt;&#xA;&lt;p&gt;Use a namespace alias as the first segment of a qualified function name:&lt;/p&gt;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&lt;div class=&#34;code-editor is-readonly is-auto-height&#34;&gt;&#xA;    &lt;textarea id=&#34;code-1-copy-clipboard&#34; class=&#34;code-editor-clipboard&#34; tabindex=&#34;-1&#34; aria-hidden=&#34;true&#34;&gt;&lt;/textarea&gt;&lt;div class=&#34;code-editor-shell&#34;&gt;&#xA;        &lt;div class=&#34;code-editor-header&#34;&gt;&#xA;            &lt;div class=&#34;code-editor-title&#34;&gt;&#xA;                &lt;span class=&#34;code-editor-dot&#34; aria-hidden=&#34;true&#34;&gt;&lt;/span&gt;&#xA;                &lt;span&gt;example.fql&lt;/span&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div class=&#34;code-editor-actions&#34;&gt;&#xA;                &lt;span class=&#34;code-editor-meta&#34;&gt;read-only&lt;/span&gt;&#xA;                &lt;button id=&#34;code-1-copy-button&#34; class=&#34;copy button is-outlined is-light code-editor-button&#34; type=&#34;button&#34;&gt;Copy&lt;/button&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;&#xA;        &lt;div class=&#34;code-editor-pane&#34;&gt;&#xA;            &lt;div id=&#34;code-1-text&#34; class=&#34;code-editor-text&#34; data-auto-height=&#34;true&#34;&gt;USE IO::NET::HTTP AS HTTP&#xA;&#xA;RETURN HTTP::GET(&amp;#34;https://api.example.com/data&amp;#34;)&lt;/div&gt;&#xA;        &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;script&gt;&#xA;        document.addEventListener(&#39;DOMContentLoaded&#39;, function () {&#xA;            const editor = ace.edit(&#39;code-1-text&#39;);&#xA;            editor.setTheme(&#34;ace\/theme\/tomorrow_night&#34;);&#xA;            editor.session.setUseWorker(false);&#xA;            editor.session.setMode(&#34;ace/mode/&#34; + &#39;fql&#39;);&#xA;            editor.setOptions({&#xA;                readOnly: true,&#xA;                highlightActiveLine: false,&#xA;                highlightGutterLine: false,&#xA;                displayIndentGuides: false,&#xA;                printMargin: false&#xA;            });&#xA;            editor.renderer.$cursorLayer.element.style.display = &#34;none&#34;&#xA;            const copyBtn = document.querySelector(&#39;#code-1-copy-button&#39;);&#xA;            const copyClipboardEl = document.querySelector(&#39;#code-1-copy-clipboard&#39;);&#xA;&#xA;            function copyTextWithFallback(content) {&#xA;                copyClipboardEl.value = content;&#xA;                copyClipboardEl.focus();&#xA;                copyClipboardEl.select();&#xA;&#xA;                if (!document.execCommand(&#39;copy&#39;)) {&#xA;                    throw new Error(&#39;Could not copy source to the clipboard&#39;);&#xA;                }&#xA;            }&#xA;&#xA;            function copyTextToClipboard(content) {&#xA;                if (navigator.clipboard &amp;&amp; navigator.clipboard.writeText) {&#xA;                    return navigator.clipboard.writeText(content).catch(() =&gt; {&#xA;                        copyTextWithFallback(content);&#xA;                    });&#xA;                }&#xA;&#xA;                copyTextWithFallback(content);&#xA;&#xA;                return Promise.resolve();&#xA;            }&#xA;&#xA;            copyBtn.addEventListener(&#39;click&#39;, () =&gt; {&#xA;                copyTextToClipboard(editor.getValue())&#xA;                    .then(() =&gt; {&#xA;                        copyBtn.textContent = &#39;Copied&#39;;&#xA;                        window.setTimeout(() =&gt; {&#xA;                            copyBtn.textContent = &#39;Copy&#39;;&#xA;                        }, 1200);&#xA;                    })&#xA;                    .catch((err) =&gt; {&#xA;                        console.error(&#39;Failed to copy source&#39;);&#xA;                        console.error(err);&#xA;                    });&#xA;            });&#xA;            function resizeAutoHeightEditor() {&#xA;                const lineHeight = editor.renderer.lineHeight || 21;&#xA;                const screenLines = Math.max(editor.session.getScreenLength(), 1);&#xA;                const nextHeight = Math.max(screenLines * lineHeight, 48);&#xA;&#xA;                editor.container.style.height = `${nextHeight}px`;&#xA;                editor.resize();&#xA;            }&#xA;&#xA;            editor.session.on(&#39;change&#39;, resizeAutoHeightEditor);&#xA;            window.addEventListener(&#39;resize&#39;, resizeAutoHeightEditor);&#xA;            resizeAutoHeightEditor();&#xA;        }, false);&#xA;    &lt;/script&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;p&gt;Here, &lt;code&gt;HTTP::GET(...)&lt;/code&gt; resolves to &lt;code&gt;IO::NET::HTTP::GET(...)&lt;/code&gt;.&lt;/p&gt;</description>
